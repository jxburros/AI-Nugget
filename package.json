{
  "name": "@jxburros/ai-nugget",
  "version": "0.3.1",
  "private": false,
  "type": "module",
  "description": "Small isomorphic AI model nugget for provider calls, policy, redaction, telemetry, and agent loops.",
  "license": "MIT",
  "author": "jxburros",
  "keywords": [
    "ai",
    "llm",
    "openai",
    "anthropic",
    "gemini",
    "ollama",
    "typescript",
    "telemetry"
  ],
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jxburros/AI-Nugget.git"
  },
  "bugs": {
    "url": "https://github.com/jxburros/AI-Nugget/issues"
  },
  "homepage": "https://github.com/jxburros/AI-Nugget#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./agent": {
      "types": "./dist/agent/index.d.ts",
      "import": "./dist/agent/index.js",
      "default": "./dist/agent/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "nugget",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "test:live": "vitest run tests/live-smoke.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:nugget": "node scripts/build-nugget.mjs",
    "demo:steel-chat": "npm run build && node examples/steel-chat/server.mjs",
    "prepublishOnly": "npm run build && npm run build:nugget"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "playwright": "^1.61.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  }
}
