{
  "name": "@jxburros/ai-handler",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Small isomorphic AI model handler nugget for provider calls, policy, redaction, telemetry, and agent loops.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./agent": {
      "types": "./dist/agent/index.d.ts",
      "import": "./dist/agent/index.js"
    }
  },
  "files": [
    "dist",
    "nugget",
    "README.md",
    "AGENTS.md",
    "CLAUDE.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:nugget": "node scripts/build-nugget.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  }
}
