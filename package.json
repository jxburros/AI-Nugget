{
  "name": "@jxburros/ai-handler",
  "version": "0.3.0",
  "private": false,
  "type": "module",
  "description": "Small isomorphic AI model handler nugget for provider calls, policy, redaction, telemetry, and agent loops.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jxburros/AI-Nugget.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./agent": {
      "types": "./dist/agent/index.d.ts",
      "import": "./dist/agent/index.js"
    }
  },
  "files": [
    "dist",
    "nugget",
    "README.md",
    "AGENTS.md",
    "CLAUDE.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "test:live": "vitest run tests/live-smoke.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:nugget": "node scripts/build-nugget.mjs",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "playwright": "^1.61.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.5"
  }
}
